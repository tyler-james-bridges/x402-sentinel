{
  "name": "x402-sentinel",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "dev:api": "pnpm --filter @x402-sentinel/bundle-api dev",
    "report:canary": "node scripts/generate-canary-report.mjs",
    "report:providers": "node scripts/generate-providers-report.mjs",
    "probe:paid": "node scripts/generate-providers-report.mjs --with-payment --max-payment 0.01 --payment-limit 3"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@x402/evm": "^2.10.0",
    "@x402/fetch": "^2.10.0",
    "@x402/mcp": "^2.10.0",
    "viem": "^2.47.17"
  }
}
